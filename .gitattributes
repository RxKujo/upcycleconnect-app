# Normalise toutes les fins de ligne en LF (Linux/Unix) dans le repo
# Les fichiers sont checkout en LF meme sur Windows -> coherent cross-OS

* text=auto eol=lf

# Sources
*.go          text eol=lf
*.php         text eol=lf
*.blade.php   text eol=lf
*.js          text eol=lf
*.ts          text eol=lf
*.jsx         text eol=lf
*.tsx         text eol=lf
*.vue         text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.html        text eol=lf
*.json        text eol=lf
*.xml         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=lf
*.sql         text eol=lf
*.sh          text eol=lf
*.env         text eol=lf
.env.example  text eol=lf

# Scripts Windows
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# Binaires
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.ico         binary
*.pdf         binary
*.zip         binary
*.tar.gz      binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.eot         binary
