# ============================================================
# Dev — Hot reload avec Air
# Le code source est monté en volume, Air recompile à chaque
# changement de fichier .go
# ============================================================
FROM golang:1.25-alpine

WORKDIR /app

RUN apk add --no-cache git curl

# Télécharger les dépendances en premier (cache layer)
COPY go.mod go.sum ./
RUN go mod download

# Installer Air pour le hot reload
RUN go install github.com/air-verse/air@latest

EXPOSE 8888

CMD ["air", "-c", ".air.toml"]
